---
/**
 * Home — "Column feel, NWO brand" (Phase 2). Rebuilt on a strict claim→proof
 * cadence: hero + living onchain feed → sourced stat band → four proof sections
 * (each a declarative claim paired with an onchain artifact, linking to its
 * "who's already live" article) → why-now (regulation) → founder snapshot →
 * FAQ → confident three-door close. Uses the shared design system + the
 * onchain-artifact components; the old scoped `.hp-*` world is retired.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
import OnchainFeed from '../components/OnchainFeed.astro';
import SettlementCard from '../components/SettlementCard.astro';
import ArtifactCode from '../components/ArtifactCode.astro';
import StatBand from '../components/StatBand.astro';
import ProofSection from '../components/ProofSection.astro';
import WhyNow from '../components/WhyNow.astro';
import FounderCard from '../components/FounderCard.astro';
import HomeFAQ from '../components/HomeFAQ.astro';
import CloseBand from '../components/CloseBand.astro';
import { TOKENIZATION_CONFIG, VAULT_POSITION, PERPS_SNAPSHOT, LIVE_NAMES } from '../lib/artifacts';
import { offerCatalogNode, faqNode } from '../lib/jsonld';
import { offerInputs } from '../lib/services';
import { HOME_FAQ } from '../lib/home-faq';

const jsonLd = [
  offerCatalogNode(offerInputs()),
  faqNode(
    HOME_FAQ.map((f) => ({ question: f.question, answer: f.answer.replace(/<[^>]+>/g, '') }))
  ),
];
---

<BaseLayout
  title="Blockchain Strategy & PoC Consulting | Northwest Onchain"
  description="The infrastructure for onchain finance is live — stablecoin settlement, tokenized assets, onchain credit, 24/7 markets. Northwest Onchain helps banks, investors, and operators find what's real and deliver the proof."
  path="/"
  image="/og/home.png"
  jsonLd={jsonLd}
>
  <!-- HERO — claim + a living onchain artifact -->
  <header class="hero-ns">
    <div class="wrap">
      <div class="hero-grid">
        <div>
          <Eyebrow>The onchain moment</Eyebrow>
          <h1>
            The infrastructure for onchain finance is <span class="serif-i">live</span>. The
            advantage goes to whoever uses it first.
          </h1>
          <p class="lead">
            Stablecoin settlement, tokenized assets, onchain credit, and round-the-clock markets are
            in production today — not someday. The hard part is knowing what's real, what's noise,
            and what it means for you.
          </p>
          <div class="hero-actions">
            <Button href="/contact" variant="primary" arrow>Start a conversation</Button>
            <Button href="#live" variant="ghost">See what's live</Button>
          </div>
          <p class="micro">
            No pitch — a straight read on whether there's something real here for you.
          </p>
        </div>
        <!-- Layered artifact composition (Column's card-over-code signature):
             the live feed with a settled-payment card floating over its edge. -->
        <div class="artifact-stack">
          <OnchainFeed />
          <div class="afloat afloat--hero drift-in" aria-hidden="true">
            <span class="afloat__k">USDC · Base</span>
            <span class="afloat__v">$1,250,000.00</span>
            <span class="afloat__s">Settled · 4s</span>
          </div>
        </div>
      </div>
    </div>
  </header>

  <!-- STAT BAND — sourced, count-up -->
  <section class="section section--stats">
    <div class="wrap">
      <StatBand />
    </div>
  </section>

  <!-- WHAT'S LIVE — section intro -->
  <section class="section section--intro" id="live">
    <div class="wrap">
      <div class="section-head fade-rise">
        <Eyebrow>What blockchain is enabling — today</Eyebrow>
        <h2>Four shifts already moving real money.</h2>
        <p class="lead">
          Not roadmap items — in production now. The question for any institution is which one
          matters to them, and whether it's worth moving on. And the ones we'll talk you out of,
          because not every problem needs a chain.
        </p>
      </div>
    </div>
  </section>

  <!-- PROOF 1 — Stablecoin settlement -->
  <ProofSection
    eyebrow="Stablecoin settlement"
    heading="Settlement that clears in seconds, not days."
    lead="Multi-day correspondent banking and FX spreads, replaced by rails that settle in minutes around the clock — stripping intermediary fees, pre-funding, and float out of payments and treasury."
    names={LIVE_NAMES.settlement}
    headingLevel={3}
  >
    <SettlementCard slot="artifact" />
    <a class="see-live" slot="foot" href="/insights/whos-already-live-stablecoin-settlement">
      See who's already live →
    </a>
  </ProofSection>

  <!-- PROOF 2 — Tokenization -->
  <ProofSection
    eyebrow="Tokenization"
    heading="Real assets, brought onchain."
    lead="Funds, credit, and real assets onchain for 24/7 transferability, fractional ownership that widens the buyer base, and near-instant liquidity for traditionally illiquid assets."
    names={LIVE_NAMES.tokenization}
    headingLevel={3}
    flip
  >
    <!-- Config → product: the rendered token card floats over its own JSON. -->
    <div class="artifact-stack" slot="artifact">
      <ArtifactCode code={TOKENIZATION_CONFIG} label="tokenization config" lang="json" />
      <div class="afloat afloat--token drift-in" aria-hidden="true">
        <span class="afloat__k">tFUND · ERC-20</span>
        <span class="afloat__v">NAV $1.00</span>
        <span class="afloat__s">Redemption T+0</span>
      </div>
    </div>
    <a class="see-live" slot="foot" href="/insights/whos-already-live-tokenizing-funds">
      See who's already live →
    </a>
  </ProofSection>

  <!-- PROOF 3 — Onchain vaults & credit -->
  <ProofSection
    eyebrow="Onchain vaults & credit"
    heading="Credit and yield with reserves you can audit."
    lead="Yield products, structured credit, and collateralized lending with transparent, real-time, auditable reserves — new revenue lines for issuers, new visibility for investors."
    names={LIVE_NAMES.credit}
    headingLevel={3}
  >
    <ArtifactCode slot="artifact" code={VAULT_POSITION} label="vault position" lang="position" />
    <a class="see-live" slot="foot" href="/insights/whos-already-live-onchain-credit">
      See who's already live →
    </a>
  </ProofSection>

  <!-- PROOF 4 — Perps & 24/7 markets -->
  <ProofSection
    eyebrow="Perps & 24/7 markets"
    heading="Markets that never close."
    lead="Round-the-clock hedging, leverage, and price exposure on venues that settle continuously, without a central clearinghouse."
    names={LIVE_NAMES.markets}
    headingLevel={3}
    flip
  >
    <ArtifactCode slot="artifact" code={PERPS_SNAPSHOT} label="perp snapshot" lang="market" />
    <a class="see-live" slot="foot" href="/insights/whos-already-live-24-7-markets">
      See who's already live →
    </a>
  </ProofSection>

  <!-- WHY NOW — the regulatory window -->
  <WhyNow />

  <!-- FOUNDER — the bridge is a person -->
  <section class="section" id="who">
    <div class="wrap">
      <div class="section-head fade-rise">
        <Eyebrow>Who's behind it</Eyebrow>
        <h2>The bridge is a person.</h2>
        <p class="lead">
          Most crypto specialists can't defend a business case to a CFO, and most finance
          professionals have never shipped onchain. Northwest Onchain exists because its founder has
          spent eight years doing both.
        </p>
      </div>
      <FounderCard variant="teaser" />
    </div>
  </section>

  <!-- FAQ -->
  <HomeFAQ />

  <!-- CLOSE — confident three doors -->
  <CloseBand />
</BaseLayout>

<style>
  /* Page-specific spacing + the proof-section "see who's live" link. The old
     scoped `.hp-*` system is gone; everything else reuses the shared system. */
  .section--stats {
    padding-top: clamp(40px, 6vh, 70px);
    padding-bottom: 0;
  }
  .section--intro {
    padding-bottom: clamp(30px, 5vh, 56px);
  }
</style>
