---
/**
 * Home. Order per IMPLEMENTATION-PLAN §2: hero → problem → use cases → why now →
 * services (4) → proof → why (4, 2×2) → process → founder teaser →
 * what-happens-next → final CTA. Dark base throughout with subtle elevation
 * (no light-band flash). Hero/use-case/why-now/FAQ copy is verbatim source.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import TopoLines from '../components/TopoLines.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';
import StepRow from '../components/StepRow.astro';
import UseCases from '../components/UseCases.astro';
import WhyNow from '../components/WhyNow.astro';
import ProofBand from '../components/ProofBand.astro';
import FounderCard from '../components/FounderCard.astro';
import HomeFAQ from '../components/HomeFAQ.astro';
import WhatHappensNext from '../components/WhatHappensNext.astro';
import CtaBand from '../components/CtaBand.astro';
import { offerCatalogNode, faqNode } from '../lib/jsonld';
import { offerInputs } from '../lib/services';
import { HOME_FAQ } from '../lib/home-faq';
import { CTA } from '../consts';

// Four services, surfaced with price up front (audit §8).
const SERVICES = [
  { id: 'audit', name: 'Opportunity Audit', price: '$1,500 · 3–5 days', blurb: 'A fast, flat-fee read on whether there is a real onchain opportunity — and what to do, or not do, about it.' },
  { id: 'sprint', name: 'Diagnostic Sprint', price: '$4k–$7.5k · 1–2 weeks', blurb: 'The opportunity, defined success metrics, a costed roadmap, and the right team — fixed fee.' },
  { id: 'delivery', name: 'PoC / Project Delivery', price: 'Build + 15–20%', blurb: 'We assemble and manage the team, then deliver a working proof of concept to the agreed metrics.' },
  { id: 'advisor', name: 'Fractional Advisor', price: '$3k–$8k/mo', blurb: 'A standing strategic seat — vendor vetting, roadmap guidance, and board-ready financial framing.' },
];

const jsonLd = [offerCatalogNode(offerInputs()), faqNode(HOME_FAQ)];
---

<BaseLayout
  title="Blockchain Strategy & PoC Consulting | Northwest Onchain"
  description="Independent blockchain consulting for banks, investors, and operators. Northwest Onchain finds where onchain creates value and delivers a working proof of concept. Start with a $1,500 Opportunity Audit."
  path="/"
  image="/og/home.png"
  jsonLd={jsonLd}
>
  <!-- HERO — left-anchored, full-bleed (homepage-hero-and-usecases.md §1) -->
  <section class="hero-bleed grain">
    <svg
      class="hero-bleed__topo"
      aria-hidden="true"
      preserveAspectRatio="xMidYMid slice"
      viewBox="0 0 1440 800"
    >
      <g fill="none" stroke="var(--moss)" stroke-width="1" opacity="0.35">
        <path d="M-40 560 C320 480 560 660 880 560 S1320 420 1500 520"></path>
        <path d="M-40 620 C340 540 580 700 900 610 S1330 470 1500 575"></path>
        <path d="M-40 500 C300 430 540 600 880 500 S1330 360 1500 460"></path>
        <path d="M-40 440 C320 370 560 530 880 440 S1320 300 1500 405"></path>
      </g>
      <path
        d="M-40 530 C300 455 545 625 880 525 S1325 388 1500 488"
        fill="none"
        stroke="var(--signal-bright)"
        stroke-width="1.2"
        opacity="0.5"></path>
    </svg>
    <div class="hero-bleed__scrim"></div>
    <div class="wrap hero-bleed__inner">
      <Eyebrow>Blockchain strategy &amp; delivery</Eyebrow>
      <h1>The bridge from <span class="accent">boardroom</span> to blockchain.</h1>
      <p class="lead">
        Stablecoin settlement, tokenized assets, onchain credit, and 24/7 markets aren't theory —
        they're in production today. We help banks, investors, and operators find where onchain
        creates real value, then deliver the proof.
      </p>
      <div class="hero-actions">
        <Button href={CTA.auditHref} variant="primary" arrow>{CTA.auditLabel}</Button>
        <Button href="#use-cases" variant="ghost" arrow>See where blockchain wins today</Button>
      </div>
      <p class="hero-cta-subtext">{CTA.auditSubtext}</p>
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <Eyebrow>The problem</Eyebrow>
        <h2>A board mandate to "do something with crypto" — and a market full of hype.</h2>
        <p class="lead">
          You can't tell a real opportunity from a pitch deck, and you don't want to hire a full
          Web3 team to find out. You need independent judgment — and a network you don't have.
        </p>
      </div>
      <div class="grid grid-3">
        <Card tag="Enterprise & TradFi" title="From mandate to proof">
          <p>
            Banks, asset managers, and operators turning a board question into a measured proof of
            concept — tokenization, settlement, payments, RWA — without betting on one agency.
          </p>
        </Card>
        <Card tag="Investors" title="Diligence, both sides">
          <p>
            VCs and family offices who need someone who reads the smart contract <em>and</em> the cap
            table before capital moves. Thesis validation and operating support.
          </p>
        </Card>
        <Card tag="Founders new to crypto" title="A credible angle">
          <p>
            Operators who want a real onchain angle — payments, loyalty, tokenization — scoped
            honestly and built by a team that won't overcharge.
          </p>
        </Card>
      </div>
    </div>
  </section>

  <!-- WHERE BLOCKCHAIN WINS — TODAY (use cases) -->
  <UseCases />

  <!-- WHY NOW (regulation) -->
  <WhyNow />

  <!-- WHAT WE DO (4 services) -->
  <section class="section section--elevated">
    <div class="wrap">
      <div class="section-head">
        <Eyebrow>What we do</Eyebrow>
        <h2>Four ways to work together.</h2>
        <p class="lead">
          Start with a low-cost diagnosis, move to delivery only when the numbers justify it, and
          keep an advisor on call if you want one. Each fee credits toward the next step if you
          continue.
        </p>
      </div>
      <div class="grid grid-4 service-grid">
        {
          SERVICES.map((s) => (
            <article class="card service-card">
              <span class="tag">{s.price}</span>
              <h3>
                <a href={`/services#${s.id}`}>{s.name}</a>
              </h3>
              <p>{s.blurb}</p>
            </article>
          ))
        }
      </div>
      <p class="section-foot">
        <Button href="/services" variant="ghost" arrow>Services &amp; pricing</Button>
      </p>
    </div>
  </section>

  <!-- PROOF BAND -->
  <ProofBand eyebrow="Track record" />

  <!-- WHY (4, 2×2) -->
  <section class="section section--elevated">
    <div class="wrap">
      <div class="section-head">
        <Eyebrow>Why Northwest Onchain</Eyebrow>
        <h2>
          Crypto specialists rarely understand the business case. Strategy firms rarely understand
          the technology. We do both.
        </h2>
      </div>
      <div class="grid grid-2 why-grid">
        <article class="card why-card">
          <span class="why-card__num" aria-hidden="true">01</span>
          <h3>Both sides of the ledger</h3>
          <p>
            Years operating in crypto, paired with real financial-modeling discipline. We can sit in
            a CFO's office and a core-dev channel the same afternoon.
          </p>
        </article>
        <article class="card why-card">
          <span class="why-card__num" aria-hidden="true">02</span>
          <h3>Network, not headcount</h3>
          <p>
            A vetted bench of builders on demand — the right team for your specific problem, instead
            of a full hire or a bet on one vendor.
          </p>
        </article>
        <article class="card why-card">
          <span class="why-card__num" aria-hidden="true">03</span>
          <h3>Metrics-first</h3>
          <p>
            Success criteria, cost, and ROI are defined before a line of code is written. No
            open-ended exploration, and big-firm rigor delivered in days instead of quarters.
          </p>
        </article>
        <article class="card why-card">
          <span class="why-card__num" aria-hidden="true">04</span>
          <h3>Vendor-neutral</h3>
          <p>
            We don't sell a chain, a token, or our own product — so the advice is independent,
            relationship-driven, and willing to say "don't" when that's the honest answer.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <Eyebrow>The expedition</Eyebrow>
        <h2>A simple, honest process: survey, chart, assemble, summit.</h2>
      </div>
      <div class="steps">
        <StepRow label="// 01 SURVEY" title="Meet & diagnose">
          We learn the business and map the terrain honestly — including where blockchain is the
          wrong tool.
        </StepRow>
        <StepRow label="// 02 CHART" title="Find the path">
          We define the opportunity, the success metrics, the costed roadmap, and the right team.
        </StepRow>
        <StepRow label="// 03 ASSEMBLE" title="Build the crew">
          We stand up the right builders from the network and align everyone on metrics, cost, and
          timeline.
        </StepRow>
        <StepRow label="// 04 SUMMIT" title="Deliver & measure">
          We run delivery to the defined metrics, prove the value, and set up what comes next.
        </StepRow>
      </div>
      <p class="section-foot">
        <Button href="/process" variant="ghost" arrow>How we work</Button>
      </p>
    </div>
  </section>

  <!-- FOUNDER TEASER -->
  <section class="section section--elevated">
    <div class="wrap">
      <div class="section-head">
        <Eyebrow>Who's behind it</Eyebrow>
        <h2>Built by an operator who has worked both sides.</h2>
      </div>
      <FounderCard variant="teaser" />
    </div>
  </section>

  <!-- FAQ -->
  <HomeFAQ />

  <!-- WHAT HAPPENS NEXT + FINAL CTA -->
  <section class="section">
    <div class="wrap">
      <div class="section-head center">
        <Eyebrow>What happens next</Eyebrow>
        <h2>From first call to a costed path.</h2>
      </div>
      <WhatHappensNext />
    </div>
  </section>

  <CtaBand
    eyebrow="Start here"
    heading="Find out if there's a real onchain opportunity."
    text="Start with a $1,500 Opportunity Audit — a fast, honest read on whether onchain is worth it for you, and what to do next."
  />
</BaseLayout>
