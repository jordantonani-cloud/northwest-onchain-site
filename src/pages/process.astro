---
/**
 * Process — the four-stage expedition (Survey → Chart → Assemble → Summit)
 * plus operating principles. Answer-first TL;DR for AEO.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import KeyTakeaways from '../components/KeyTakeaways.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Card from '../components/Card.astro';
import StepRow from '../components/StepRow.astro';
import ProofSection from '../components/ProofSection.astro';
import ScopeCard from '../components/ScopeCard.astro';
import CtaBand from '../components/CtaBand.astro';
---

<BaseLayout
  title="Our Process | Survey, Chart, Assemble, Summit | Northwest Onchain"
  description="The Northwest Onchain process: a four-stage expedition from diagnosis to delivery. Survey the terrain, chart the path, assemble the crew, summit. Metrics and cost defined before any code is written."
  path="/process"
  image="/og/process.png"
  breadcrumbs={[{ name: 'Process', path: '/process' }]}
>
  <PageHero
    eyebrow="The expedition"
    lead="Read the terrain before you climb. Agree the route and the cost, bring the right crew, and measure the summit."
  >
    Survey. Chart. Assemble. Summit.
  </PageHero>

  <!-- ANSWER-FIRST TL;DR (AEO) -->
  <section class="section" style="padding-bottom:0">
    <div class="wrap">
      <KeyTakeaways
        label="The process in four stages"
        lead="Northwest Onchain runs every engagement as a four-stage expedition. Survey (meet and diagnose), Chart (define the opportunity, metrics, and costed roadmap), Assemble (stand up the right builders), Summit (deliver and prove the value). Success criteria and cost are defined before a line of code is written."
        points={[
          'Survey and Chart are delivered in a short diagnostic (1–2 weeks).',
          'You manage one relationship: us. We coordinate the network behind it.',
          'Vendor-neutral, so we can recommend "don\'t build" when that is the honest answer.',
        ]}
      />
    </div>
  </section>

  <!-- STEPS -->
  <section class="section">
    <div class="wrap">
      <h2 class="sr-only">The four stages</h2>
      <div class="steps">
        <StepRow label="// 01 SURVEY" title="Meet & diagnose" headingLevel={2}>
          We sit down and learn the business: the ambition, the constraints, the pressure behind the
          mandate. Sometimes that means telling you the summit you're pointed at isn't worth the
          climb. No deck, no pitch.
        </StepRow>
        <StepRow label="// 02 CHART" title="Find the path" headingLevel={2}>
          We define the real opportunity, the success metrics, the costed roadmap, and the team. You
          get a route with milestones, a budget, and a business case you can stand behind.
        </StepRow>
        <StepRow label="// 03 ASSEMBLE" title="Build the crew" headingLevel={2}>
          We stand up the right builders from a vetted network, matched to your problem. Everyone
          aligns on metrics, cost, and timeline before work begins. You manage one relationship: us.
        </StepRow>
        <StepRow label="// 04 SUMMIT" title="Deliver & measure" headingLevel={2}>
          We deliver against the metrics we agreed and prove the value with real numbers. Then
          production, scale, or a clear stop.
        </StepRow>
      </div>
    </div>
  </section>

  <!-- CHART, MADE CONCRETE — claim + scope artifact -->
  <ProofSection
    eyebrow="The deliverable"
    heading="Every climb gets a route, a budget, and a turnaround line."
    lead="The Chart stage resolves to a concrete plan: milestones, a timeline, and a cost band, known before anyone sets out."
    flip
  >
    <ScopeCard slot="artifact" />
    <a class="see-live" slot="foot" href="/services">See how we work together →</a>
  </ProofSection>

  <!-- PRINCIPLES -->
  <section class="section alt">
    <div class="wrap">
      <div class="section-head fade-rise">
        <Eyebrow>Principles</Eyebrow>
        <h2>How we keep it real.</h2>
      </div>
      <div class="grid-3 fade-rise grid">
        <Card title="Metrics before code">
          <p>
            Success criteria, cost, and ROI are defined up front. If we can't agree what winning
            looks like, we don't start.
          </p>
        </Card>
        <Card title='Honest "no"'>
          <p>
            The most valuable thing we can sometimes say is "don't." Vendor-neutrality means we're
            free to say it.
          </p>
        </Card>
        <Card title="A single point of accountability">
          <p>
            You manage one relationship. We coordinate the network, the timeline, and the
            deliverables behind it.
          </p>
        </Card>
        <Card title="Both sides fluent">
          <p>
            Every recommendation is grounded in both the technology and the business case. No
            hand-waving either direction.
          </p>
        </Card>
        <Card title="Cost transparency">
          <p>You see the build budget and our fee. No mystery markups, no padded hours.</p>
        </Card>
        <Card title="Built to hand off">
          <p>
            We deliver in a way you can own and scale, not a black box that keeps you dependent.
          </p>
        </Card>
      </div>
    </div>
  </section>

  <CtaBand
    eyebrow="Start here"
    heading="Ready to survey the terrain?"
    text="One conversation. A fast, honest read on what's actually worth building."
  />
</BaseLayout>
