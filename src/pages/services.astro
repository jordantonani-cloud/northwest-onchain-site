---
/**
 * Services — how the partnership works. Three engagement shapes (Diagnose →
 * Deliver → Advise) with honest pricing context, not a menu of packages
 * (STRATEGIC-REVISION-PROMPT directive 5). Carries OfferCatalog + FAQPage
 * JSON-LD; the FAQ array drives both the accordion and the schema.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Card from '../components/Card.astro';
import Faq, { type FaqItem } from '../components/Faq.astro';
import ProofBand from '../components/ProofBand.astro';
import ProofSection from '../components/ProofSection.astro';
import ScopeCard from '../components/ScopeCard.astro';
import CtaBand from '../components/CtaBand.astro';
import { ENGAGEMENTS, PRICING_CONTEXT, offerInputs } from '../lib/services';
import { offerCatalogNode, faqNode } from '../lib/jsonld';

const faqs: FaqItem[] = [
  {
    question: 'Is the first conversation really free?',
    answer:
      'Yes. Thirty minutes, no pitch, no deck. You leave with a straight read on whether there is a real opportunity. If there is, we scope a short diagnostic together. The judgment stays independent because we have nothing else to sell you.',
  },
  {
    question: 'Do you build it yourselves?',
    answer:
      "We assemble and manage the right team from a vetted network rather than carrying a fixed engineering staff. You get builders matched to <em>your</em> problem, and we own the coordination, metrics, and delivery so you don't have to manage a vendor.",
  },
  {
    question: 'Are you tied to a particular chain or product?',
    answer:
      "No. We're vendor-neutral and chain-agnostic. We don't resell a platform or hold a position that biases the recommendation. The answer is whatever serves your business.",
  },
  {
    question: 'How fast can we get to a working pilot?',
    answer:
      'A diagnostic runs one to two weeks. From there, most pilots deliver within weeks, not quarters, with metrics and cost agreed before any build begins.',
  },
  {
    question: 'What makes you different from a big consulting firm?',
    answer:
      "Big firms write the deck and bill the hours, but have rarely shipped onchain. Crypto-native shops can ship but can't make the business case. We do both, and we price against outcomes, not billable time.",
  },
];

const jsonLd = [
  offerCatalogNode(offerInputs()),
  faqNode(faqs.map((f) => ({ question: f.question, answer: f.answer.replace(/<[^>]+>/g, '') }))),
];
---

<BaseLayout
  title="Blockchain Strategy & Execution Services | Northwest Onchain"
  description="How a Northwest Onchain partnership works: find the onchain opportunity, prove it with a working pilot, stay ahead as the rules evolve. Vendor-neutral, Seattle-based."
  path="/services"
  image="/og/services.png"
  breadcrumbs={[{ name: 'Services', path: '/services' }]}
  jsonLd={jsonLd}
>
  <PageHero
    eyebrow="How we work together"
    lead="We position your business for the onchain moment: better distribution, lower costs, better outcomes for your stakeholders. It starts with a free conversation."
  >
    A partnership, not a package.
  </PageHero>

  <!-- THE PARTNERSHIP -->
  <section class="section">
    <div class="wrap">
      <div class="section-head fade-rise">
        <Eyebrow>The partnership</Eyebrow>
        <h2>Three ways the work takes shape.</h2>
        <p class="lead">
          Every engagement runs through one diligence: why build, what to build, who builds it. The
          shape depends on where you are.
        </p>
      </div>
      <div class="grid-3 fade-rise grid" data-stagger>
        {
          ENGAGEMENTS.map((e) => (
            <article class="card engagement-card fade-rise" id={e.id}>
              <span class="tag">{e.tag}</span>
              <h3>{e.name}</h3>
              <p>{e.blurb}</p>
              <ul class="engagement-list">
                {e.features.map((f) => (
                  <li>{f}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
      <p class="pricing-note">{PRICING_CONTEXT}</p>
    </div>
  </section>

  <!-- WHAT DELIVERY LOOKS LIKE — claim + scope artifact -->
  <ProofSection
    eyebrow="What delivery looks like"
    heading="Ambition becomes a costed, shippable plan."
    lead="Milestones, a timeline, and a cost band agreed before any build. No open-ended hours, no mystery scope."
    flip
  >
    <ScopeCard slot="artifact" />
    <a class="see-live" slot="foot" href="/process">See how we work →</a>
  </ProofSection>

  <!-- WHERE WE CREATE VALUE -->
  <section class="section alt">
    <div class="wrap">
      <div class="section-head fade-rise">
        <Eyebrow>Where we create value</Eyebrow>
        <h2>The opportunities we help you act on.</h2>
        <p class="lead">
          The goal is business outcomes: lower cost, faster settlement, new revenue, wider
          distribution. Never technology for its own sake.
        </p>
      </div>
      <div class="grid-3 fade-rise grid">
        <Card title="Tokenization & RWA">
          <p>
            Real-world assets, funds, and instruments brought onchain, scoped for compliance and
            liquidity from day one.
          </p>
        </Card>
        <Card title="Payments & settlement">
          <p>
            Stablecoin rails that cut multi-day settlement to minutes, modeled against your actual
            cost of capital.
          </p>
        </Card>
        <Card title="Onchain credit & vaults">
          <p>
            Lending and yield products with transparent, auditable reserves. New revenue for
            issuers, new visibility for users.
          </p>
        </Card>
        <Card title="Derivatives & 24/7 markets">
          <p>Round-the-clock hedging and price exposure on venues that settle continuously.</p>
        </Card>
        <Card title="Diligence & thesis validation">
          <p>
            Technical and financial diligence on crypto and tokenization deals. We read the contract
            and the cap table.
          </p>
        </Card>
        <Card title="Loyalty & digital assets">
          <p>
            Programs and digital assets that drive retention and revenue, without the speculative
            baggage.
          </p>
        </Card>
        <Card title="Infrastructure & chain selection">
          <p>Neutral guidance on chains, custody, and architecture, chosen for your constraints.</p>
        </Card>
        <Card title="Strategy & business casing">
          <p>
            Clear business cases and unit economics, so the decision is easy to defend and easy to
            act on.
          </p>
        </Card>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section">
    <div class="wrap">
      <div class="section-head fade-rise">
        <Eyebrow>Straight answers</Eyebrow>
        <h2>Questions buyers actually ask.</h2>
      </div>
      <Faq items={faqs} />
    </div>
  </section>

  <ProofBand eyebrow="Track record" />

  <CtaBand
    eyebrow="Start here"
    heading="Start with a conversation."
    text="A straight read on whether onchain is worth it for you, and what it would take."
  />
</BaseLayout>
