---
/**
 * About — the E-E-A-T anchor. Story, beliefs, and the founder Person schema
 * (founder of the Organization). Founder identity is config-driven (consts.FOUNDER)
 * with honest placeholders until the owner fills real details.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import KeyTakeaways from '../components/KeyTakeaways.astro';
import Eyebrow from '../components/Eyebrow.astro';
import Card from '../components/Card.astro';
import FounderCard from '../components/FounderCard.astro';
import ProofBand from '../components/ProofBand.astro';
import CtaBand from '../components/CtaBand.astro';
import { FOUNDER } from '../consts';
import { personNode } from '../lib/jsonld';

const jsonLd = [
  personNode({
    name: FOUNDER.name,
    jobTitle: FOUNDER.jobTitle,
    description: FOUNDER.bio.join(' '),
    knowsAbout: [...FOUNDER.knowsAbout],
    sameAs: [...FOUNDER.sameAs],
    image: FOUNDER.image || undefined,
    location: FOUNDER.location,
  }),
];
---

<BaseLayout
  title="About | Northwest Onchain — TradFi Rigor, Onchain Fluency"
  description="Northwest Onchain is built on years operating in crypto and a vetted builder network, paired with real financial-modeling discipline. The rare both-sides partner for organizations going onchain — grounded in the Pacific Northwest."
  path="/about"
  image="/og/about.png"
  breadcrumbs={[{ name: 'About', path: '/about' }]}
  jsonLd={jsonLd}
>
  <PageHero
    eyebrow="About"
    lead="Northwest Onchain exists because the people deciding whether to go onchain deserve an advisor who speaks both languages fluently — and isn't selling them a chain."
  >
    Built on both sides of the ledger.
  </PageHero>

  <!-- ANSWER-FIRST TL;DR (AEO) -->
  <section class="section" style="padding-bottom:0">
    <div class="wrap">
      <KeyTakeaways
        label="Who we are"
        lead="Northwest Onchain is a Pacific Northwest–based blockchain strategy and execution consultancy that bridges traditional finance and onchain technology. It is built on years operating in crypto and a vetted builder network, paired with genuine financial-modeling discipline — the rare both-sides advisor who can size an opportunity the way a CFO would and assemble the team to deliver it the way a native would."
        points={[
          'Vendor-neutral: no chain, token, or product to sell — including the freedom to say "don\'t build."',
          'Network, not headcount — the right builders for each problem, not a fixed bench.',
          'Relationship-driven and low-hype, grounded in the Pacific Northwest.',
        ]}
      />
    </div>
  </section>

  <!-- FOUNDER -->
  <section class="section">
    <div class="wrap">
      <div class="section-head fade-rise">
        <Eyebrow>The founder</Eyebrow>
        <h2>The bridge is a person.</h2>
        <p class="lead">
          Most crypto specialists can't defend a business case to a CFO, and most finance
          professionals have never shipped onchain. Northwest Onchain exists because its founder has
          spent eight years doing both.
        </p>
      </div>
      <FounderCard variant="full" />
    </div>
  </section>

  <!-- PROOF -->
  <ProofBand eyebrow="Track record" />

  <!-- BELIEFS -->
  <section class="section alt">
    <div class="wrap">
      <div class="section-head fade-rise">
        <Eyebrow>What we believe</Eyebrow>
        <h2>A few convictions we won't compromise.</h2>
      </div>
      <div class="grid-2 fade-rise grid">
        <Card title="Outcomes beat technology">
          <p>
            Nobody's board wants "a blockchain." They want lower cost, faster settlement, or new
            revenue. We start from the outcome and work back — the tech is a means, never the point.
          </p>
        </Card>
        <Card title="Independence is the product">
          <p>
            The moment an advisor has a chain or token to sell, their advice is compromised. Staying
            vendor-neutral is how we stay worth paying for.
          </p>
        </Card>
        <Card title="Networks beat headcount">
          <p>
            The best team for your problem rarely sits on one payroll. A vetted network lets us
            match the right builders to the right job, every time.
          </p>
        </Card>
        <Card title="Trust compounds">
          <p>
            This is a relationship business. We optimize for the second engagement, the referral,
            and the long arc — not the quick close.
          </p>
        </Card>
      </div>
    </div>
  </section>

  <CtaBand
    eyebrow="Start here"
    heading="Let's see if there's a fit."
    text="If you want an advisor who'll give you the straight read — including when the answer is no — start with a $1,500 Opportunity Audit."
  />
</BaseLayout>
