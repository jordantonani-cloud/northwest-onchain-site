---
/**
 * Eyebrow — the mono kicker label (e.g. "// 01 SURVEY"). The `//` marker is
 * rendered by default to match the brand pattern; pass marker={false} to omit.
 */
interface Props {
  center?: boolean;
  marker?: boolean;
  /** "copper" tints the label for the regulatory/heritage sections. */
  variant?: 'signal' | 'copper';
  class?: string;
}
const { center = false, marker = true, variant = 'signal', class: className = '' } = Astro.props;
---

<span class:list={['eyebrow', { center, 'eyebrow--copper': variant === 'copper' }, className]}>
  {marker && <span aria-hidden="true">// </span>}<slot />
</span>
