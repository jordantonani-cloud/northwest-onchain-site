---
/**
 * WhatHappensNext — the 3-step "We meet → We scope → You get the path" sequence.
 * Originally on Contact (a genuine trust asset, WEBSITE-AUDIT §8); reused near
 * the homepage final CTA. `compact` drops the section chrome for inline use.
 */
interface Props {
  compact?: boolean;
  class?: string;
}
const { compact = false, class: className = '' }: Props = Astro.props;

const STEPS = [
  {
    n: '01',
    title: 'We meet',
    body: 'A 30-minute call to understand the ambition and the constraints. No pitch.',
  },
  {
    n: '02',
    title: 'We scope the work',
    body: 'If there is a fit, we agree a fixed-fee Audit or Sprint — scope, timeline, price.',
  },
  {
    n: '03',
    title: 'You get the path',
    body: 'Defined metrics, a costed roadmap, and the right team — ready to build, or an honest no.',
  },
];
---

<div class:list={['what-next', { 'what-next--compact': compact }, className]}>
  {STEPS.map((s) => (
    <div class="what-next__step">
      <span class="what-next__num" aria-hidden="true">{s.n}</span>
      <h3 class="what-next__title">{s.title}</h3>
      <p class="what-next__body">{s.body}</p>
    </div>
  ))}
</div>
