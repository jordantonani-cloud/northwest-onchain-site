---
/**
 * WhyItem — a numbered differentiator row (mono index + heading + copy).
 */
interface Props {
  num: string;
  title: string;
}
const { num, title }: Props = Astro.props;
---

<div class="why-item">
  <span class="why-num" aria-hidden="true">{num}</span>
  <div>
    <h3>{title}</h3>
    <p><slot /></p>
  </div>
</div>
