---
/**
 * CloseBand — the confident, low-pressure close. One statement, one button
 * (STRATEGIC-REVISION-PROMPT directive 5). The three-door close is retired:
 * one ask sitewide, the free conversation.
 */
import Eyebrow from './Eyebrow.astro';
import Button from './Button.astro';
import { CTA } from '../consts';

interface Props {
  eyebrow?: string;
  heading?: string;
  text?: string;
  class?: string;
}
const {
  eyebrow = "Let's talk",
  heading = 'Ready for the <em>onchain</em> moment?',
  text = 'One conversation. A straight read on what onchain means for your business, including an honest no.',
  class: className = '',
} = Astro.props;
---

<section class:list={['close-band', className]} aria-labelledby="close-heading">
  <div class="wrap">
    <Eyebrow center>{eyebrow}</Eyebrow>
    <h2 id="close-heading" class="close-band__h" set:html={heading} />
    <p class="close-band__p">{text}</p>
    <div class="close-band__action">
      <Button href={CTA.primaryHref} variant="primary" arrow>{CTA.primaryLabel}</Button>
    </div>
    <p class="cta-band__subtext">{CTA.subtext}</p>
  </div>
</section>
