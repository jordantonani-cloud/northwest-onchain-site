---
/**
 * PeakMark — the "Beacon" mark (Brand Book v1.0 §2.1): a Cascade peak drawn as
 * two edges meeting at a summit node, anchored by two base nodes, with two
 * concentric signal rings radiating from the apex. Fuses peak (PNW) + node graph
 * (blockchain) + beacon (signal). Master geometry on a 64×64 artboard — scaled,
 * never redrawn. Colors are exact brand values per variant (this IS the logo).
 */
interface Props {
  /** light: full color on light bg · dark: brightened for dark bg · mono: single currentColor. */
  variant?: 'light' | 'dark' | 'mono';
  size?: number;
  class?: string;
}
const { variant = 'dark', size = 30, class: className = '' }: Props = Astro.props;

const c =
  variant === 'mono'
    ? {
        ring: 'currentColor',
        ringO1: '0.28',
        ringO2: '0.55',
        slope: 'currentColor',
        base: 'currentColor',
        apex: 'currentColor',
      }
    : variant === 'light'
      ? {
          ring: '#2FBF98',
          ringO1: '0.28',
          ringO2: '0.55',
          slope: '#12463A',
          base: '#12463A',
          apex: '#2FBF98',
        }
      : {
          ring: '#34E0B5',
          ringO1: '0.3',
          ringO2: '0.6',
          slope: '#5BD9BB',
          base: '#2E8A70',
          apex: '#34E0B5',
        };
---

<svg
  class:list={['peak-mark', className]}
  width={size}
  height={size}
  viewBox="0 0 64 64"
  fill="none"
  aria-hidden="true"
  focusable="false"
>
  <circle cx="32" cy="18" r="12.5" fill="none" stroke={c.ring} stroke-width="1" opacity={c.ringO1}
  ></circle>
  <circle cx="32" cy="18" r="8" fill="none" stroke={c.ring} stroke-width="1.3" opacity={c.ringO2}
  ></circle>
  <path
    d="M16 46 L32 18 L48 46"
    fill="none"
    stroke={c.slope}
    stroke-width="3"
    stroke-linecap="round"
    stroke-linejoin="round"></path>
  <circle cx="16" cy="46" r="3.2" fill={c.base}></circle>
  <circle cx="48" cy="46" r="3.2" fill={c.base}></circle>
  <circle cx="32" cy="18" r="4.5" fill={c.apex}></circle>
</svg>
