---
/**
 * Button — primary (teal) or ghost (outline) pill. Renders an <a> when `href`
 * is given, otherwise a <button>. `arrow` appends the trailing → glyph.
 */
interface Props {
  href?: string;
  variant?: 'primary' | 'ghost';
  arrow?: boolean;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  [key: string]: unknown;
}
const {
  href,
  variant = 'primary',
  arrow = false,
  type = 'button',
  class: className = '',
  ...rest
} = Astro.props;

const classes = ['btn', `btn-${variant}`, arrow && 'btn-arrow', className];
---

{
  href ? (
    <a href={href} class:list={classes} {...rest}>
      <slot />
    </a>
  ) : (
    <button type={type} class:list={classes} {...rest}>
      <slot />
    </button>
  )
}
