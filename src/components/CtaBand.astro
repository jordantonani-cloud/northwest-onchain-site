---
/**
 * CtaBand — the recurring conversion band. ONE ask sitewide: the free first
 * conversation (STRATEGIC-REVISION-PROMPT directive 5). Calm and confident,
 * no packages, no prices.
 */
import Eyebrow from './Eyebrow.astro';
import Button from './Button.astro';
import { CTA } from '../consts';

interface Props {
  heading: string;
  text?: string;
  eyebrow?: string;
}
const { heading, text, eyebrow = 'Start here' } = Astro.props;
---

<section class="section cta-band grain">
  <div class="wrap">
    <Eyebrow center>{eyebrow}</Eyebrow>
    <h2>{heading}</h2>
    {text && <p>{text}</p>}
    <div class="cta-band__actions">
      <Button href={CTA.primaryHref} variant="primary" arrow>{CTA.primaryLabel}</Button>
    </div>
    <p class="cta-band__subtext">{CTA.subtext}</p>
  </div>
</section>
