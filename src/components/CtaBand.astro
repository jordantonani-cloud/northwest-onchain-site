---
/**
 * CtaBand — the recurring conversion band. Drives the north-star action:
 * book the Meet (default) or buy the Audit. Used at the foot of every page.
 */
import Eyebrow from './Eyebrow.astro';
import Button from './Button.astro';
import { SITE, BOOKING } from '../consts';

interface Props {
  heading: string;
  text?: string;
  ctaLabel?: string;
  ctaHref?: string;
  eyebrow?: string;
}
const {
  heading,
  text,
  ctaLabel = BOOKING.ctaLabel,
  ctaHref = '/contact',
  eyebrow = SITE.tagline,
} = Astro.props;
---

<section class="section cta-band grain">
  <div class="wrap">
    <Eyebrow center>{eyebrow}</Eyebrow>
    <h2>{heading}</h2>
    {text && <p>{text}</p>}
    <Button href={ctaHref} variant="primary" arrow>{ctaLabel}</Button>
  </div>
</section>
