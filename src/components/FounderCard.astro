---
/**
 * FounderCard — the human behind the firm (WEBSITE-AUDIT §9, copy §2).
 * `variant="teaser"` (homepage) shows the short pitch + links; `variant="full"`
 * (About) shows the complete bio. Headshot is a TODO(owner) placeholder until
 * a real image lands at FOUNDER.image.
 */
import { FOUNDER } from '../consts';
import PeakMark from './PeakMark.astro';

interface Props {
  variant?: 'teaser' | 'full';
  class?: string;
}
const { variant = 'teaser', class: className = '' }: Props = Astro.props;
const initials = FOUNDER.name
  .split(' ')
  .map((w) => w[0])
  .join('')
  .slice(0, 2);
---

<div class:list={['founder', `founder--${variant}`, className]}>
  <div class="founder-photo">
    {
      FOUNDER.image ? (
        <img
          src={FOUNDER.image}
          alt={`${FOUNDER.name}, ${FOUNDER.jobTitle} of Northwest Onchain`}
          width="320"
          height="400"
          loading="lazy"
        />
      ) : (
        <div class="founder-photo__placeholder" role="img" aria-label={`Headshot of ${FOUNDER.name} (coming soon)`}>
          <PeakMark variant="dark" size={40} />
          <span class="founder-photo__initials">{initials}</span>
          {/* TODO(owner): add a professional headshot — set FOUNDER.image in src/consts.ts. */}
        </div>
      )
    }
  </div>

  <div class="founder-body">
    <p class="founder-role">{FOUNDER.jobTitle} · {FOUNDER.location}</p>
    <h3 class="founder-name">{FOUNDER.name}</h3>

    {
      variant === 'full' ? (
        <div class="founder-bio">
          {FOUNDER.bio.map((para) => (
            <p>{para}</p>
          ))}
        </div>
      ) : (
        <p class="founder-teaser">{FOUNDER.teaser}</p>
      )
    }

    <p class="founder-links">
      {variant === 'teaser' && <a href="/about">Read the full background</a>}
      <a href={FOUNDER.linkedin} rel="me noopener" target="_blank">LinkedIn ↗</a>
    </p>
  </div>
</div>
