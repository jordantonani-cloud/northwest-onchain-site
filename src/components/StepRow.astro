---
/**
 * StepRow — one stage of the expedition (mono stage label + heading + copy).
 * `label` is the full mono kicker, e.g. "// 01 SURVEY".
 */
interface Props {
  label: string;
  title: string;
  /** Heading level for the step title (default h3, used under a section h2). */
  headingLevel?: 2 | 3;
}
const { label, title, headingLevel = 3 }: Props = Astro.props;
const Heading = `h${headingLevel}` as 'h2' | 'h3';
---

<div class="step">
  <span class="num">{label}</span>
  <div>
    <Heading>{title}</Heading>
    <p><slot /></p>
  </div>
</div>
