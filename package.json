{
  "name": "northwest-onchain-site",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Marketing website for Northwest Onchain — blockchain strategy & execution consulting. Onchain, on purpose.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "gen:assets": "node scripts/gen-assets.mjs",
    "prebuild": "node scripts/gen-assets.mjs",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint . --ext .js,.ts,.astro",
    "format": "prettier --write \"**/*.{js,ts,mjs,astro,md,mdx,json,css}\"",
    "format:check": "prettier --check \"**/*.{js,ts,mjs,astro,md,mdx,json,css}\"",
    "lhci": "lhci autorun"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.2.0",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^6.0.2",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.1.1",
    "@fontsource-variable/jetbrains-mono": "^5.1.2",
    "@fontsource-variable/space-grotesk": "^5.1.1",
    "astro": "^5.4.0",
    "astro-icon": "^1.1.5",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@eslint/js": "^9.20.0",
    "@lhci/cli": "^0.14.0",
    "astro-eslint-parser": "^1.2.1",
    "eslint": "^9.20.0",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.5.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
